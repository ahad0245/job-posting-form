PORT=3000
CEIPAL_AUTH_EMAIL=your-email@example.com
CEIPAL_AUTH_PASSWORD=your-password
CEIPAL_API_KEY=your-api-key
CEIPAL_JOB_POST_URL=https://api.ceipal.com/savecustomJobPostingDetails/your-account-path/
ZOHO_RECRUIT_API_DOMAIN=https://recruit.zohocloud.ca
ZOHO_RECRUIT_BASE_URL=https://recruit.zohocloud.ca
ZOHO_RECRUIT_ACCOUNTS_DOMAIN=https://accounts.zohocloud.ca
ZOHO_RECRUIT_ACCESS_TOKEN=your-access-token
ZOHO_RECRUIT_REFRESH_TOKEN=your-refresh-token
ZOHO_RECRUIT_SCOPE=ZohoRecruit.modules.jobopening.CREATE
ZOHO_RECRUIT_MODULE=Job Openings
ZOHO_RECRUIT_CLIENT_ID=your-client-id
ZOHO_RECRUIT_CLIENT_SECRET=your-client-secret
ZOHO_RECRUIT_GRANT_TOKEN=
ZOHO_RECRUIT_REDIRECT_URI=https://www.zoho.com
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEET_TAB=posted jobs

# Local development option
GOOGLE_SERVICE_ACCOUNT_FILE=C:\path\to\google-service-account.json

# Production / Vercel option
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
